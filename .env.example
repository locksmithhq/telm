# App
APP_PORT=4000
HTTP_PORT=8080
GRPC_PORT=9317

# Database
POSTGRES_HOST=database
POSTGRES_USER=telm
POSTGRES_PASSWORD=SUBSTITUIR
POSTGRES_DB=telm
POSTGRES_PORT=5432
SSL_MODE=disable

# Auth — obrigatório em produção
# Gere o JWT_SECRET com: openssl rand -base64 32
JWT_SECRET=SUBSTITUIR
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SUBSTITUIR

# Produção (opcional)
# HTTPS=true                              # ativa flag Secure no cookie
# CORS_ORIGIN=https://telm.example.com   # restringir origem (vírgula para múltiplas)

# Generator (usado com: make gen)
GEN_WORKERS=5
GEN_SLEEP_MS=0
# GEN_SERVICE_NAME=gen-service
# GEN_OTLP_ENDPOINT=otelcollector-telm:4318
